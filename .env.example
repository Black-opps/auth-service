# API Settings
API_VERSION=v1
API_PORT=8007
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://mpesa_user:secure_password@postgres:5432/auth_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_TTL=3600

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=mpesa-saas-auth
JWT_AUDIENCE=mpesa-saas-api

# API Keys
API_KEY_PREFIX=mpesa_live_
API_KEY_LENGTH=48

# MFA
MFA_ISSUER_NAME=M-PESA SaaS
MFA_TOTP_DIGITS=6
MFA_TOTP_PERIOD=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Login Attempts
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8003,http://localhost:8004,http://localhost:8005,http://localhost:8006

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
